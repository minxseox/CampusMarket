{{>layout/header}}

<div class="container my-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">중고 장터</h3>
        <a href="/" class="btn btn-outline-secondary btn-sm">목록으로</a>
    </div>

    <div class="row g-4 mb-5">
        <!-- 왼쪽 이미지 영역 -->
        <div class="col-md-8">
            <div class="bg-light d-flex align-items-center justify-content-center text-muted rounded"
                 style="height: 520px;">
                이미지 없음
            </div>
        </div>

        <!-- 오른쪽 상품 정보 카드 -->
        <div class="col-md-4">
            <div class="card p-4 shadow-sm">
                <h4 class="fw-bold mb-3">전공책</h4>

                <div class="mb-3">
                    <span class="badge-status status-sale me-2">판매중</span>
                    <span class="text-muted">전자기기</span>
                </div>

                <hr>

                <p class="text-muted mb-1">가격</p>
                <h3 class="fw-bold">₩40,000</h3>

                <hr>

                <p class="text-muted mb-1">설명</p>
                <p>필기감 있음</p>

                <hr>

                <p class="text-muted mb-2">판매 상태 변경</p>
                <select class="form-select w-50 mb-3">
                    <option>판매중</option>
                    <option>예약중</option>
                    <option>판매완료</option>
                </select>

                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-secondary w-50">수정</a>
                    <button class="btn btn-danger w-50">삭제</button>
                </div>
            </div>
        </div>
    </div>

    <!-- 댓글 영역 -->
    <div class="mt-5">
        <h4 class="fw-bold mb-4">댓글</h4>

        <!-- 댓글 작성 -->
        <div class="card p-4 mb-4 shadow-sm">
            <form action="/product/1/comments" method="post">
                <textarea name="content"
                          class="form-control mb-3"
                          rows="3"
                          placeholder="댓글을 입력하세요..."></textarea>

                <button type="submit" class="btn btn-secondary">
                    댓글 등록
                </button>
            </form>
        </div>

        <!-- 댓글 목록 임시 -->
        <div class="card p-4 mb-3 shadow-sm">
            <div class="d-flex justify-content-between">
                <div>
                    <h6 class="fw-bold mb-1">익명</h6>
                    <p class="text-muted small">2026. 5. 15.</p>
                </div>

                <form action="/comments/1/delete" method="post">
                    <button type="submit" class="btn btn-link text-dark text-decoration-none">
                        삭제
                    </button>
                </form>
            </div>

            <p class="mt-3 mb-0">네고 가능한가요?</p>
        </div>
    </div>

</div>

<style>
    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .status-sale {
        background-color: #e8f9f1;
        color: #11c16e;
        border: 1px solid #b8f0d2;
    }
</style>

{{>layout/footer}}