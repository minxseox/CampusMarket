{{>layout/header}}

<div class="container my-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">중고 장터</h3>
        <a href="/main" class="btn btn-outline-secondary btn-sm">목록으로</a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-8">
            <div class="bg-light d-flex align-items-center justify-content-center text-muted rounded"
                 style="height: 520px;">
                {{#product.imagePath}}
                    <img src="{{product.imagePath}}" alt="{{product.title}}" class="w-100 h-100 object-fit-cover rounded">
                {{/product.imagePath}}
                {{^product.imagePath}}
                    이미지 없음
                {{/product.imagePath}}
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-4 shadow-sm">
                <h4 class="fw-bold mb-3">{{product.title}}</h4>

                <div class="mb-3">
                    <span class="badge-status status-sale me-2">{{product.status}}</span>
                </div>

                <hr>

                <p class="text-muted mb-1">가격</p>
                <h3 class="fw-bold">₩{{product.price}}</h3>

                <hr>

                <p class="text-muted mb-1">설명</p>
                <p>{{product.content}}</p>

                {{#isAuthor}}
                    <hr>

                    <p class="text-muted mb-2">판매 상태 변경</p>
                    <form action="/product/{{id}}/status" method="post" class="d-flex gap-2 mb-3">
                        <input type="hidden" name="_method" value="put">

                        <select name="status" class="form-select w-50">
                            <option value="SALE">판매중</option>
                            <option value="RESERVED">예약중</option>
                            <option value="SOLD">판매완료</option>
                        </select>
                        <button type="submit" class="btn btn-primary btn-sm">적용</button>
                    </form>

                    <div class="d-flex gap-2">
                        <a href="/product/{{id}}/edit" class="btn btn-outline-secondary w-50">수정</a>
                        <button type="button" onclick="deleteProduct({{id}})" class="btn btn-danger w-50">삭제</button>
                    </div>
                {{/isAuthor}}
            </div>
        </div>
    </div>

    <div class="mt-5">
        <h4 class="fw-bold mb-4">댓글</h4>

        <div class="card p-4 mb-4 shadow-sm">
            <form action="/product/{{id}}/comments" method="post">
                <textarea name="content"
                          class="form-control mb-3"
                          rows="3"
                          placeholder="댓글을 입력하세요..."></textarea>

                <button type="submit" class="btn btn-secondary">
                    댓글 등록
                </button>
            </form>
        </div>

        <div class="card p-4 mb-3 shadow-sm">
            <div class="d-flex justify-content-between">
                <div>
                    <h6 class="fw-bold mb-1">익명</h6>
                    <p class="text-muted small">2026. 5. 15.</p>
                </div>

                <form action="/comments/1/delete" method="post">
                    <button type="submit" class="btn btn-link text-dark text-decoration-none">
                        삭제
                    </button>
                </form>
            </div>

            <p class="mt-3 mb-0">네고 가능한가요?</p>
        </div>
    </div>

</div>

<style>
    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .status-sale {
        background-color: #e8f9f1;
        color: #11c16e;
        border: 1px solid #b8f0d2;
    }
</style>

<script>
    // 상태 변경 JS는 삭제했고, 기존의 삭제 기능만 남겨두었습니다.
    function deleteProduct(productId) {
        if (!confirm("정말 이 상품을 삭제하시겠습니까?")) {
            return;
        }

        // 백엔드 통제실에 DELETE 신호를 다이렉트로 전송!
        fetch('/api/product/' + productId, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            }
        })
                .then(response => {
                    if (response.ok) {
                        alert("상품이 삭제되었습니다.");
                        window.location.href = '/main'; // 삭제 성공 후 메인 목록으로 복귀
                    } else {
                        alert("상품 삭제가 안됐습니다.");
                    }
                })
                .catch(error => {
                    console.error("Error:", error);
                    alert("서버와 통신 중 에러가 발생했습니다.");
                });
    }
</script>

{{>layout/footer}}