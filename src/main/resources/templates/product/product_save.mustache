{{>layout/header}}


<div class="container mb-5" style="max-width: 900px; padding: 0 20px;">
    <h2 class="mb-4 font-weight-bold text-dark" style="font-size: 28px; letter-spacing: -1px; padding-left: 15px;">상품 등록</h2>

    <div class="card p-5" style="border: 1px solid #eaeaea; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.02);">
        <form id="productForm">

            <div class="form-group mb-4">
                <label class="font-weight-bold text-dark mb-2" style="font-size: 15px;">제목 <span class="text-danger">*</span></label>
                <input type="text" class="form-control" id="title" placeholder="상품 제목을 입력하세요"
                       style="height: 48px; border: 1px solid #e1e1e1; border-radius: 8px; font-size: 14px; padding-left: 15px;">
            </div>

            <div class="form-group mb-4">
                <label class="font-weight-bold text-dark mb-2" style="font-size: 15px;">카테고리 <span class="text-danger">*</span></label>
                <select name="category" class="form-control text-muted" id="category"
                        style="height: 48px; border: 1px solid #e1e1e1; border-radius: 8px; font-size: 14px; padding-left: 15px;">
                    <option value="" disabled selected>카테고리를 선택하세요</option>
                    <option value="DIGITAL">디지털기기</option>
                    <option value="CLOTHES">의류/잡화</option>
                    <option value="BOOKS">도서/티켓</option>
                    <option value="OTHERS">기타 중고물품</option>
                </select>
            </div>

            <div class="form-group mb-4">
                <label class="font-weight-bold text-dark mb-2" style="font-size: 15px;">가격 (원) <span class="text-danger">*</span></label>
                <input type="number" class="form-control" id="price" value="0"
                       style="height: 48px; border: 1px solid #e1e1e1; border-radius: 8px; font-size: 14px; padding-left: 15px;">
            </div>

            <div class="form-group mb-4">
                <label class="font-weight-bold text-dark mb-2" style="font-size: 15px;">설명</label>
                <textarea class="form-control" id="content" rows="4" placeholder="상품에 대한 설명을 입력하세요"
                          style="border: 1px solid #e1e1e1; border-radius: 8px; font-size: 14px; padding: 15px; resize: none;"></textarea>
            </div>

            <div class="form-group mb-5">
                <label class="font-weight-bold text-dark mb-2" style="font-size: 15px;">이미지</label>
                <input type="file" class="form-control pt-2" id="image"
                       style="height: 48px; border: 1px solid #e1e1e1; border-radius: 8px; font-size: 14px; padding-left: 15px; color: #6c757d;">
            </div>

            <div class="row g-3" style="gap: 12px; padding: 0 15px;">
                <button type="button" class="btn text-white font-weight-bold col" id="btn-save"
                        style="background-color: #1a1515; height: 50px; border-radius: 8px; font-size: 15px; max-width: 260px;">상품 등록</button>
                <a href="/" class="btn btn-light text-dark font-weight-bold col border"
                   style="background-color: #ffffff; border-color: #e1e1e1 !important; height: 50px; border-radius: 8px; font-size: 15px; line-height: 36px; max-width: 260px;">취소</a>
            </div>

        </form>
    </div>
</div>

<script>
    document.getElementById('btn-save').addEventListener('click', function () {
        const data = {
            title: document.getElementById('title').value,
            price: document.getElementById('price').value ? parseInt(document.getElementById('price').value) : 0,
            content: document.getElementById('content').value,
            category: document.getElementById("category").value
        };

        fetch('/api/v1/product', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json; charset=utf-8' },
            body: JSON.stringify(data)
        })
                .then(response => response.text())
                .then(result => {
                    if (result === 'success') {
                        alert('🎉 상품 등록이 완료되었습니다!');
                        window.location.href = '/';
                    } else {
                        alert('⚠️ 등록 실패: ' + result);
                    }
                });
    });
</script>

{{>layout/footer}}