{{>layout/header}}

<div class="row mb-4">
    <div class="col-12">
        <h5 class="fw-bold mb-3" style="letter-spacing: -0.5px;">카테고리</h5>
        <div class="d-flex flex-wrap gap-2">
            <button onclick="filter('category', 'ALL')" class="btn btn-capsule" data-category="ALL">전체</button>
            <button onclick="filter('category', 'BOOK')" class="btn btn-capsule" data-category="BOOK">전공책</button>
            <button onclick="filter('category', 'ITEM')" class="btn btn-capsule" data-category="ITEM">비품</button>
            <button onclick="filter('category', 'DIGITAL')" class="btn btn-capsule" data-category="DIGITAL">전자기기</button>
            <button onclick="filter('category', 'CLOTHES')" class="btn btn-capsule" data-category="CLOTHES">의류</button>
            <button onclick="filter('category', 'ETC')" class="btn btn-capsule" data-category="ETC">기타</button>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <h5 class="fw-bold mb-3" style="letter-spacing: -0.5px;">판매 상태</h5>
        <div class="d-flex flex-wrap gap-2">
            <button onclick="filter('status', 'ALL')" class="btn btn-capsule" data-status="ALL">전체</button>
            <button onclick="filter('status', '판매중')" class="btn btn-capsule" data-status="판매중">판매중</button>
            <button onclick="filter('status', '예약중')" class="btn btn-capsule" data-status="예약중">예약중</button>
            <button onclick="filter('status', '판매완료')" class="btn btn-capsule" data-status="판매완료">판매완료</button>
        </div>
    </div>
</div>

<form action="/main" method="get" class="row mb-4" onsubmit="return handleSearchSubmit(this)">
    <div class="col-md-10">
        <input type="text" name="keyword" class="form-control" placeholder="상품명을 검색하세요" value="{{keyword}}">
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-dark w-100">검색</button>
    </div>
</form>

<div class="row mb-3 mt-5">
    <div class="col-12">
        <h4 class="fw-bold" style="letter-spacing: -0.5px;">전체 상품</h4>
    </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">

    {{#products}}
        <div class="col">
            <a href="/product/{{id}}" class="card h-100 product-card text-decoration-none text-dark">
                <div class="card-img-top bg-light-gray d-flex align-items-center justify-content-center text-muted">
                    {{#imagePath}}
                        <img src="{{imagePath}}" alt="{{title}}" class="w-100 h-100 object-fit-cover rounded-top-2">
                    {{/imagePath}}
                    {{^imagePath}}
                        <span>이미지 없음</span>
                    {{/imagePath}}
                </div>
                <div class="card-body p-3 d-flex flex-column justify-content-between">
                    <div>
                        <h6 class="fw-bold mb-1 text-dark" style="font-size: 1.05rem;">{{title}}</h6>
                        <p class="text-secondary mb-3 text-truncate" style="font-size: 0.9rem;">{{content}}</p>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <span class="fw-bold text-dark" style="font-size: 1.15rem;">₩{{price}}</span>

                        <span class="badge-status
                        {{#sale}}status-sale{{/sale}}
                        {{#reserved}}status-reserved{{/reserved}}
                        {{#sold}}status-sold{{/sold}}">
                            {{status}}
                        </span>
                    </div>
                </div>
            </a>
        </div>
    {{/products}}

    {{^products}}
        <div class="col">
            <div class="card h-100 product-card text-decoration-none text-dark">
                <div class="card-img-top bg-light-gray d-flex align-items-center justify-content-center text-muted">
                    <span>이미지 없음</span>
                </div>
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1 text-dark" style="font-size: 1.05rem;">등록된 상품이 없습니다.</h6>
                    <p class="text-secondary mb-3 text-truncate" style="font-size: 0.9rem;">첫 상품을 등록해 보세요!</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-dark" style="font-size: 1.15rem;">₩0</span>
                        <span class="badge-status status-sold">대기중</span>
                    </div>
                </div>
            </div>
        </div>
    {{/products}}

</div>

<style>
    /* 둥근 알약 모양 카테고리 버튼 */
    .btn-capsule {
        border-radius: 30px;
        padding: 8px 18px;
        font-size: 0.9rem;
        font-weight: 500;
        border: 1px solid #e9e9e9;
        background-color: #ffffff;
        color: #555555;
        transition: all 0.2s;
    }
    .btn-capsule:hover {
        background-color: #f8f9fa;
        border-color: #cccccc;
    }
    .btn-capsule.active {
        background-color: #111111 !important;
        border-color: #111111 !important;
        color: #ffffff !important;
    }

    /* 상품 카드 및 기타 스타일 유지 */
    .product-card {
        border: 1px solid #eef0f2;
        border-radius: 12px !important;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.04);
    }
    .bg-light-gray {
        background-color: #eaeaea;
        height: 240px;
        min-height: 240px;
        font-size: 0.95rem;
    }
    .badge-status {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .status-sale { background-color: #e8f9f1; color: #11c16e; }
    .status-reserved { background-color: #fff6e6; color: #ff9f00; }
    .status-sold { background-color: #f1f3f5; color: #868e96; }
</style>

<script>
    function filter(type, value) {
        const urlParams = new URLSearchParams(window.location.search);
        if (value === 'ALL') {
            urlParams.delete(type);
        } else {
            urlParams.set(type, value);
        }
        window.location.href = '/main?' + urlParams.toString();
    }

    window.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const currentCategory = urlParams.get('category');
        const currentStatus = urlParams.get('status');

        if (currentCategory) {
            const targetBtn = document.querySelector(`[data-category="${currentCategory}"]`);
            if (targetBtn) targetBtn.classList.add('active');
        } else {
            const allBtn = document.querySelector('[data-category="ALL"]');
            if (allBtn) allBtn.classList.add('active');
        }

        if (currentStatus) {
            const targetBtn = document.querySelector(`[data-status="${currentStatus}"]`);
            if (targetBtn) targetBtn.classList.add('active');
        } else {
            const allBtn = document.querySelector('[data-status="ALL"]');
            if (allBtn) allBtn.classList.add('active');
        }
    });

    function handleSearchSubmit(form) {
        const keyword = form.keyword.value.trim();
        
        if (!keyword) {
            window.location.href = '/main';
            return false;
        }

        return true;
    }
</script>

{{>layout/footer}}