{{>layout/header}}

<div class="row mb-4">
    <div class="col-12">
        <h5 class="fw-bold mb-3" style="letter-spacing: -0.5px;">카테고리</h5>
        <div class="d-flex flex-wrap gap-2">
            <a href="/" class="btn btn-capsule active">전체</a>
            <a href="/?category=BOOK" class="btn btn-capsule">전공책</a>
            <a href="/?category=ITEM" class="btn btn-capsule">비품</a>
            <a href="/?category=DIGITAL" class="btn btn-capsule">전자기기</a>
            <a href="/?category=CLOTHES" class="btn btn-capsule">의류</a>
            <a href="/?category=ETC" class="btn btn-capsule">기타</a>
        </div>
    </div>
</div>

<div class="row mb-3 mt-5">
    <div class="col-12">
        <h4 class="fw-bold" style="letter-spacing: -0.5px;">전체 상품</h4>
    </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">

    {{#products}}
        <div class="col">
            <a href="/product/{{id}}" class="card h-100 product-card text-decoration-none text-dark">

                <div class="card-img-top bg-light-gray d-flex align-items-center justify-content-center text-muted">
                    {{#imagePath}}
                        <img src="{{imagePath}}" alt="{{title}}" class="w-100 h-100 object-fit-cover rounded-top-2">
                    {{/imagePath}}
                    {{^imagePath}}
                        <span>이미지 없음</span>
                    {{/imagePath}}
                </div>

                <div class="card-body p-3 d-flex flex-column justify-content-between">
                    <div>
                        <h6 class="fw-bold mb-1 text-dark" style="font-size: 1.05rem;">{{locationTag}}</h6>
                        <p class="text-secondary mb-3 text-truncate" style="font-size: 0.9rem;">{{title}}</p>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <span class="fw-bold text-dark" style="font-size: 1.15rem;">₩{{priceValue}}</span>

                        <span class="badge-status {{statusClass}}">
                            {{statusText}}
                        </span>
                    </div>

                    <div class="text-muted mt-2 border-top pt-2" style="font-size: 0.75rem;">
                        {{categoryText}}
                    </div>
                </div>
            </a>
        </div>
    {{/products}}

    {{^products}}
        <div class="col">
            <a href="/product/1" class="card h-100 product-card text-decoration-none text-dark">
                <div class="card-img-top bg-light-gray d-flex align-items-center justify-content-center text-muted">
                    <span>이미지 없음</span>
                </div>
                <div class="card-body p-3">
                    <h6 class="fw-bold mb-1 text-dark" style="font-size: 1.05rem;"> 전공책</h6>
                    <p class="text-secondary mb-3 text-truncate" style="font-size: 0.9rem;">필기감 있음</p>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-dark" style="font-size: 1.15rem;">₩25,000</span>
                        <span class="badge-status status-sale">판매중</span>
                    </div>
                    <div class="text-muted mt-2 border-top pt-2" style="font-size: 0.75rem;">
                        전자기기
                    </div>
                </div>
            </a>
        </div>
    {{/products}}

</div>

<style>
    /* 둥근 알약 모양 카테고리 버튼 */
    .btn-capsule {
        border-radius: 30px;
        padding: 8px 18px;
        font-size: 0.9rem;
        font-weight: 500;
        border: 1px solid #e9e9e9;
        background-color: #ffffff;
        color: #555555;
        transition: all 0.2s;
    }
    .btn-capsule:hover {
        background-color: #f8f9fa;
        border-color: #cccccc;
    }
    .btn-capsule.active {
        background-color: #111111;
        border-color: #111111;
        color: #ffffff;
    }

    /* 상품 카드 기본 틀 */
    .product-card {
        border: 1px solid #eef0f2;
        border-radius: 12px !important;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.04);
    }

    /* 이미지 없음 회색 영역 고정 높이 */
    .bg-light-gray {
        background-color: #eaeaea;
        height: 240://px;
        min-height: 240px;
        font-size: 0.95rem;
        letter-spacing: -0.5px;
    }

    /* 상태 뱃지 공통 스타일 */
    .badge-status {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    /* 판매중 (연한 초록) */
    .status-sale {
        background-color: #e8f9f1;
        color: #11c16e;
    }
    /* 예약중 (연한 주황) */
    .status-reserved {
        background-color: #fff6e6;
        color: #ff9f00;
    }
    /* 판매완료 (연한 회색) */
    .status-sold {
        background-color: #f1f3f5;
        color: #868e96;
    }
</style>

{{>layout/footer}}