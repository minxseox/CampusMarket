<!doctype html>
<html lang="ko">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>중고 장터</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* 폰트 및 기본 여백 세팅 */
        body {
            font-family: 'Noto Sans KR', sans-serif;
            background-color: #ffffff;
            padding-top: 100px; /* 헤더 높이만큼 본문 내리기 */
        }

        /* 상단 헤더 스타일 영역 */
        .custom-header {
            background-color: #ffffff;
            border-bottom: 1px solid #f1f1f1;
            height: 80px;
        }

        /* 중앙 로고 타이틀 스타일 */
        .header-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: #000000;
            text-decoration: none;
            letter-spacing: -0.5px;
        }

        /* 오른쪽 사용자 정보 및 버튼 세트 */
        .user-nav-item {
            font-size: 0.95rem;
            color: #555555;
        }

        /* [상품 등록] 블랙 버튼 */
        .btn-black {
            background-color: #000000;
            color: #ffffff;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 6px;
            border: none;
            font-size: 0.9rem;
            transition: background-color 0.2s;
        }
        .btn-black:hover {
            background-color: #222222;
            color: #ffffff;
        }

        /* [마이페이지] 아웃라인 버튼 */
        .btn-outline-gray {
            background-color: #ffffff;
            color: #333333;
            border: 1px solid #dcdcdc;
            font-weight: 400;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }
        .btn-outline-gray:hover {
            background-color: #f8f9fa;
            border-color: #b5b5b5;
        }
    </style>
</head>
<body>

<header class="custom-header fixed-top d-flex align-items-center">
    <div class="container d-flex justify-content-between align-items-center">

        <div style="width: 250px;" class="d-none d-lg-block"></div>

        <div class="text-center">
            <a href="/" class="header-title">중고 장터</a>
        </div>

        <div class="d-flex align-items-center justify-content-end gap-3" style="min-width: 250px;">

            {{#userName}}
                <span class="user-nav-item me-1">{{userName}} 김</span>
                <a href="/product/save" class="btn btn-black text-decoration-none">상품 등록</a>
                <a href="/mypage" class="btn btn-outline-gray text-decoration-none">마이페이지</a>
            {{/userName}}

            {{^userName}}
                <a href="/login" class="btn btn-outline-gray text-decoration-none" style="padding: 6px 12px; font-size: 0.85rem;">로그인</a>
            {{/userName}}

        </div>

    </div>
</header>

<div class="container">