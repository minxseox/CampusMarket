{{> layout/header}}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <h3 class="mb-4 text-center" style="font-weight: 700;">로그인</h3>
        <form action="/user/login" method="post">
            {{#error}}
                <div class="alert alert-danger" style="font-size: 0.85rem; border-radius: 6px;">아이디 또는 비밀번호가 올바르지 않습니다.</div>
            {{/error}}

            <div class="mb-3">
                <label for="username" class="form-label" style="font-size: 0.9rem; font-weight: 500;">아이디</label>
                <input type="text" class="form-control" id="username" name="username" required style="border-radius: 6px; padding: 10px;">
            </div>

            <div class="mb-4">
                <label for="password" class="form-label" style="font-size: 0.9rem; font-weight: 500;">비밀번호</label>
                <input type="password" class="form-control" id="password" name="password" required style="border-radius: 6px; padding: 10px;">
            </div>

            <button type="submit" class="btn btn-black w-100" style="padding: 12px; font-weight: 600;">로그인</button>
        </form>
        <div class="text-center mt-3">
            <a href="/user/signup" class="text-muted" style="font-size: 0.85rem; text-decoration: none;">아직 회원이 아니신가요? 회원가입</a>
        </div>
    </div>
</div>

{{> layout/footer}}