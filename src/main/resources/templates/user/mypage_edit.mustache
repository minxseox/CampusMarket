{{> layout/header}}

<div class="container" style="margin-top: 40px; margin-bottom: 80px; max-width: 600px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 style="font-weight: 700; color: #212529;">정보 수정</h3>
        <a href="/user/mypage" class="btn btn-outline-secondary btn-sm">취소</a>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 10px;">
        <div class="card-body p-5">
            <form action="/user/mypage/edit" method="post">

                <div class="mb-4">
                    <label for="nickname" class="form-label" style="font-size: 0.9rem; font-weight: 500;">닉네임</label>
                    <input type="text" class="form-control" id="nickname" name="nickname" value="{{nickname}}" required style="border-radius: 6px; padding: 10px;">
                </div>

                <div class="mb-5">
                    <label for="email" class="form-label" style="font-size: 0.9rem; font-weight: 500;">이메일 주소</label>
                    <input type="email" class="form-control" id="email" name="email" value="{{email}}" required style="border-radius: 6px; padding: 10px;">
                </div>

                <button type="submit" class="btn btn-dark w-100" style="padding: 12px; font-weight: 600;">수정 완료</button>
            </form>
        </div>
    </div>

</div>

{{> layout/footer}}