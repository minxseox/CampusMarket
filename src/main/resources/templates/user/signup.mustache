{{> layout/header}}

<div class="row justify-content-center" style="margin-top: 50px;">
    <div class="col-md-5">
        <h3 class="mb-4 text-center" style="font-weight: 700;">회원가입</h3>
        <form action="/user/signup" method="post">
            <input type="hidden" name="_csrf" value="{{_csrf.token}}"/>

            <div class="mb-3">
                <label for="username" class="form-label" style="font-size: 0.9rem; font-weight: 500;">아이디</label>
                <input type="text" class="form-control" id="username" name="username" placeholder="아이디를 입력하세요" required style="border-radius: 6px; padding: 10px;">
            </div>
            <div class="mb-3">
                <label for="email" class="form-label" style="font-size: 0.9rem; font-weight: 500;">이메일 주소</label>
                <input type="email" class="form-control" id="email" name="email" placeholder="example@domain.com" required style="border-radius: 6px; padding: 10px;">
            </div>
            <div class="mb-4">
                <label for="password" class="form-label" style="font-size: 0.9rem; font-weight: 500;">비밀번호</label>
                <input type="password" class="form-control" id="password" name="password" placeholder="비밀번호를 입력하세요" required style="border-radius: 6px; padding: 10px;">
            </div>
            <button type="submit" class="btn btn-black w-100" style="padding: 12px; font-weight: 600;">가입하기</button>
        </form>
        <div class="text-center mt-3">
            <a href="/user/login" class="text-muted" style="font-size: 0.85rem; text-decoration: none;">이미 계정이 있으신가요? 로그인</a>
        </div>
    </div>
</div>

{{> layout/footer}}