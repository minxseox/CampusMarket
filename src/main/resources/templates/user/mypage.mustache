{{>layout/header}}

<div class="container my-5">
    <h2 class="fw-bold mb-4">마이페이지</h2>

    <h5 class="fw-bold mb-3">내가 등록한 상품</h5>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
        {{#products}}
            <div class="col">
                <a href="/product/{{id}}" class="card h-100 product-card text-decoration-none text-dark">
                    <div class="card-img-top bg-light-gray d-flex align-items-center justify-content-center text-muted">
                        이미지 없음
                    </div>

                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-2">{{title}}</h6>
                        <p class="text-secondary text-truncate">{{content}}</p>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">₩{{price}}</span>
                            <span class="badge-status
                                {{#sale}}status-sale{{/sale}}
                                {{#reserved}}status-reserved{{/reserved}}
                                {{#sold}}status-sold{{/sold}}">
                                {{status}}
                            </span>
                        </div>
                    </div>
                </a>
            </div>
        {{/products}}

        {{^products}}
            <p class="text-muted">등록한 상품이 없습니다.</p>
        {{/products}}
    </div>
</div>

<style>
    .product-card {
        border: 1px solid #eef0f2;
        border-radius: 12px !important;
        overflow: hidden;
    }

    .bg-light-gray {
        background-color: #eaeaea;
        height: 220px;
        min-height: 220px;
    }

    .badge-status {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-sale {
        background-color: #e8f9f1;
        color: #11c16e;
        border: 1px solid #b8f0d2;
    }

    .status-reserved {
        background-color: #fff6e6;
        color: #ff9f00;
        border: 1px solid #ffd27a;
    }

    .status-sold {
        background-color: #f1f3f5;
        color: #868e96;
        border: 1px solid #d5d8dc;
    }
</style>

{{>layout/footer}}