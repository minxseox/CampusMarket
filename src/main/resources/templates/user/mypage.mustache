{{> layout/header}}

<div class="container" style="margin-top: 40px; margin-bottom: 80px; background-color: #f8f9fa; padding: 40px; border-radius: 15px;">

    <h3 class="mb-4" style="font-weight: 700; color: #212529;">마이페이지</h3>

    <div class="card border-0 mb-5" style="border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-4" style="font-size: 1.1rem; color: #333;">계정 정보</h5>
            <div class="row text-start">
                <div class="col-md-4 mb-3 mb-md-0">
                    <p class="text-muted mb-2" style="font-size: 0.85rem;">사용자명</p>
                    <p class="fs-6 mb-0" style="font-weight: 600;">{{nickname}}</p>
                </div>
                <div class="col-md-4 mb-3 mb-md-0">
                    <p class="text-muted mb-2" style="font-size: 0.85rem;">이메일</p>
                    <p class="fs-6 mb-0" style="font-weight: 600;">{{email}}</p>
                </div>
                <div class="col-md-4">
                    <p class="text-muted mb-2" style="font-size: 0.85rem;">가입일</p>
                    <p class="fs-6 mb-0" style="font-weight: 600;">{{createdDate}}</p>
                </div>
            </div>
        </div>
    </div>

    <h5 class="fw-bold mb-3" style="font-size: 1.1rem; color: #333;">내가 등록한 상품</h5>
    <hr class="mb-4" style="border-top: 2px solid #212529; opacity: 1;">

    <div class="row row-cols-1 row-cols-md-3 g-4">

        {{#products}}
            <div class="col">
                <a href="/product/{{id}}" class="text-decoration-none text-dark d-block h-100">
                    <div class="card h-100 border-0 shadow-sm" style="border-radius: 10px; overflow: hidden; transition: transform 0.2s;">

                        <div style="height: 200px; background-color: #eee; display: flex; align-items: center; justify-content: center; position: relative;">
                            <span style="color: #adb5bd; font-size: 0.9rem;">📸 {{title}}</span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold mb-1 text-truncate">{{title}}</h6>
                            <p class="text-muted mb-3" style="font-size: 0.8rem;">캠퍼스 직거래 상품</p>

                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <span class="fw-bold" style="font-size: 1.15rem;">{{price}}원</span>

                                <span class="badge" style="
                                        background-color: {{statusColor}};
                                        color: {{statusTextColor}};
                                        padding: 8px 12px;
                                        font-weight: 500;
                                        border-radius: 6px;
                                        ">
                                    {{status}}
                                </span>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        {{/products}}

        {{^products}}
            <div class="col-12 text-center py-5">
                <div class="mb-3" style="font-size: 3rem;">📦</div>
                <p class="text-muted mb-0" style="font-size: 1rem;">아직 등록한 상품이 없습니다.<br>첫 번째 상품을 등록해 보세요!</p>
                <a href="/product/save" class="btn btn-dark mt-3" style="padding: 10px 20px;">상품 등록하기</a>
            </div>
        {{/products}}

    </div>
</div>

{{> layout/footer}}